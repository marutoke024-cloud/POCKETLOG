# Firebase Web アプリの設定（Firebase コンソール → プロジェクト設定 → マイアプリ）
# これらは秘匿情報ではなく公開しても問題ないが、コミットしたくない場合は
# .env.local にコピーして使う（.gitignore 済み）。
# 設定画面から貼り付ける運用にする場合は、この .env は未設定でもよい。
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# 注意: Gemini API キーはここに置かない。
# 静的サイトでは公開されてしまうため、アプリの「設定」画面から各端末で入力する。
